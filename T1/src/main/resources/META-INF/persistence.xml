<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="clinica-pu" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>udesc.br.model.Agenda</class>
        <class>udesc.br.model.Aplicacao</class>
        <class>udesc.br.model.Consulta</class>
        <class>udesc.br.model.Despesa</class>
        <class>udesc.br.model.Entrada</class>
        <class>udesc.br.model.Medicamento</class>
        <class>udesc.br.model.MovimentacaoFinanceira</class>
        <class>udesc.br.model.Paciente</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.sqlite.JDBC" />
            <property name="jakarta.persistence.jdbc.url" value="jdbc:sqlite:banco.db" />
<!--            <property name="jakarta.persistence.jdbc.user" value="postgres" />-->
<!--            <property name="jakarta.persistence.jdbc.password" value="PGCEAVI" />-->

            <property name="hibernate.dialect" value="org.hibernate.community.dialect.SQLiteDialect" />
            <property name="hibernate.show_sql" value="true" />
            <property name="hibernate.format_sql" value="true" />

            <property name="hibernate.hbm2ddl.auto" value="update" />
        </properties>
    </persistence-unit>
</persistence>